---
import BaseLayout from '../layouts/baseLayout.astro';

const user = Astro.locals.user ?? null; // Get user from middleware context, default to null if not set
---

<BaseLayout
  title="Home - Astro SSR Starter"
  description="Welcome to the Astro SSR starter template"
>
  <div class="py-12">
    <div class="max-w-2xl mx-auto">
      <h1 class="text-4xl font-bold text-gray-900 mb-6">
        Welcome to Astro SSR Starter
      </h1>
      <p class="text-lg text-gray-600 mb-8">
        A minimal, generic starter kit ready for GitHub → Vercel deployment with
        SSR support, authentication, Tailwind CSS, and API routes.
      </p>

      {user ? (
        <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-8">
          <p class="text-green-800">
            ✓ You are logged in as <strong>{user.email}</strong>
          </p>
          <a
            href="/account"
            class="mt-4 inline-block px-6 py-2 bg-green-600 text-white rounded hover:bg-green-700 transition"
          >
            Go to Your Account
          </a>
        </div>
      ) : (
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-8">
          <p class="text-blue-800 mb-4">
            Sign up or login to access your account.
          </p>
          <a
            href="/auth"
            class="inline-block px-6 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 transition"
          >
            Get Started
          </a>
        </div>
      )}

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-12">
        <div class="bg-gray-50 p-6 rounded-lg border border-gray-200">
          <h3 class="text-xl font-semibold text-gray-900 mb-3">⚡ Fast</h3>
          <p class="text-gray-600">
            Built with Astro's fast-by-default approach and optimized for SSR.
          </p>
        </div>
        <div class="bg-gray-50 p-6 rounded-lg border border-gray-200">
          <h3 class="text-xl font-semibold text-gray-900 mb-3">🔐 Secure</h3>
          <p class="text-gray-600">
            Supabase authentication and session management built-in.
          </p>
        </div>
        <div class="bg-gray-50 p-6 rounded-lg border border-gray-200">
          <h3 class="text-xl font-semibold text-gray-900 mb-3">🎨 Styled</h3>
          <p class="text-gray-600">
            Tailwind CSS included for rapid UI development.
          </p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
