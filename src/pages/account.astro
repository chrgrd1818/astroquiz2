---
import BaseLayout from '../layouts/baseLayout.astro';
import { dbLayer } from './api/db.js';

// This page is protected by middleware - only authenticated users can access it
const user = Astro.locals.user ?? null; // Get user from middleware context, default to null if not set
const session = Astro.locals.session ?? null; // Get session from middleware context, default to null if not set

if (!user) {
  return Astro.redirect('/');
}

let profile;
let error = null;

try {
  // Fetch user profile from database
  profile = await dbLayer.getUserProfile(Astro, user.id);
} catch (e) {
 error = e instanceof Error ? e.message : 'Failed to fetch profile';
  // ...
  profile = {
    id: user.id,
    email: user.email,
    created_at: user.created_at,
  };
}
---

<BaseLayout
  title="Account - Astro SSR Starter"
  description="Your account dashboard"
>
  <div class="py-12 max-w-2xl mx-auto">
    <h1 class="text-3xl font-bold text-gray-900 mb-8">Your Account</h1>

    {error && (
      <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-8">
        <p class="text-yellow-800">{error}</p>
      </div>
    )}

    <div class="bg-white border border-gray-200 rounded-lg p-8 shadow-sm">
      <h2 class="text-xl font-semibold text-gray-900 mb-6">Profile Information</h2>

      <div class="space-y-4 mb-8">
        <div>
          <label class="block text-sm font-medium text-gray-700">Email</label>
          <p class="text-gray-900 font-mono text-lg mt-1">
            {profile?.email || user.email}
          </p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">
            User ID
          </label>
          <p class="text-gray-600 font-mono text-sm mt-1 break-all">
            {profile?.id || user.id}
          </p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">
            Account Created
          </label>
          <p class="text-gray-900 mt-1">
            {profile?.created_at
              ? new Date(profile.created_at).toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })
              : user.created_at
                ? new Date(user.created_at).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })
                : 'Unknown'}
          </p>
        </div>
      </div>

      <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-8">
        <h3 class="font-semibold text-blue-900 mb-2">Session Active</h3>
        <p class="text-blue-800 text-sm">
          Your authentication token is valid and your session is active.
        </p>
      </div>

      <div class="space-y-3">
        <button
          onclick="alert('Edit profile feature coming soon')"
          class="w-full px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 transition"
        >
          Edit Profile
        </button>
        <form method="POST" action="/api/auth/logout">
          <button
            type="submit"
            class="w-full px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700 transition"
          >
            Logout
          </button>
        </form>
      </div>
    </div>
  </div>
</BaseLayout>