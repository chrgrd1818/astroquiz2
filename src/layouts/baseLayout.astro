---
import Nav from '../components/nav.astro';
import '../assets/main.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Astro SSR App', description = 'A minimal Astro SSR starter' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
  </head>
  <body>
    <Nav />
    <main class="container mx-auto px-4 py-8">
      <slot />
    </main>
    <footer class="text-center py-8 text-gray-500 text-sm border-t mt-12">
      <p>&copy; 2024 Astro SSR Starter. All rights reserved.</p>
    </footer>
    <script src="../assets/main.js"></script>
  </body>
</html>